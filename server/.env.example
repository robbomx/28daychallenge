PORT=4000

# The deployed URL of your frontend (for CORS). During local dev this is the
# Vite dev server address.
FRONTEND_URL=http://localhost:5173

# Secret used to sign login sessions. Set this to a long random string in
# production — do not use the default.
JWT_SECRET=change-me-to-a-long-random-string

# From the Stripe Dashboard -> Developers -> API keys (use the SECRET key,
# not the publishable one).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# From the Stripe Dashboard -> Developers -> Webhooks -> your endpoint ->
# "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# The Stripe Payment Link you created for the $39 one-time purchase
# (Payment links -> your link -> copy URL). Do NOT include query params here,
# the server adds client_reference_id and prefilled_email automatically.
PAYMENT_LINK_BASE_URL=https://buy.stripe.com/xxxxxxxxxxxx
