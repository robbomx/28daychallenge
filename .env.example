# URL of the deployed backend server (see /server). During local dev with
# `npm run dev`, this defaults to http://localhost:4000 if left unset.
VITE_API_URL=http://localhost:4000

# Your Meta (Facebook/Instagram) Pixel ID. Find it in Meta Events Manager ->
# your pixel -> Settings. Leave unset and the site simply won't load the
# pixel at all — no errors, no broken tracking calls.
VITE_META_PIXEL_ID=
